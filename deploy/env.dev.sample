# Nombre de archivo: env.dev.sample
# Ubicación de archivo: deploy/env.dev.sample
# Descripción: Variables de entorno para el entorno de DESARROLLO (Dev) — copiar a .env.dev en la raíz del proyecto

# ─── BASE DE DATOS (DEV) ──────────────────────────────────────────────────────
# Apunta a la base focas_dev para aislar completamente datos de producción
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=focas_dev
POSTGRES_USER=FOCALBOT
POSTGRES_PASSWORD=LASFOCAS_DEV_2026!

# ─── Bot de Telegram ──────────────────────────────────────────────────────────
# Dejar vacío para deshabilitar el bot en dev (evita colisión con el bot de prod)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_IDS=11111111,22222222

# ─── NLP / LLM ────────────────────────────────────────────────────────────────
# heuristic por defecto en dev: no consume API externa, sin costos
LLM_PROVIDER=heuristic
OPENAI_API_KEY=
OLLAMA_URL=http://ollama:11434
INTENT_THRESHOLD=0.7
LANG=es
LOG_RAW_TEXT=false
INTENT_CLARIFY_PROVIDER=heuristic
INTENT_ACTION_PROVIDER=heuristic
INTENT_DOMAIN_CLASSIFIER=heuristic
INTENT_ENABLE_ANSWERS=true
INTENT_MAX_ANSWER_CHARS=800
INTENT_ACTIONS_ENABLED=repetitividad_report

# ─── Informes ─────────────────────────────────────────────────────────────────
TEMPLATES_DIR=/app/Templates
SLA_TEMPLATE_PATH=${TEMPLATES_DIR}/Template_Informe_SLA.docx
REP_TEMPLATE_PATH=${TEMPLATES_DIR}/Plantilla_Informe_Repetitividad.docx
REPORTS_DIR=/app/data/reports
UPLOADS_DIR=/app/data/uploads
SOFFICE_BIN=/usr/bin/soffice
MAPS_ENABLED=false
MAPS_LIGHTWEIGHT=true

# ─── Web/UI (DEV) ─────────────────────────────────────────────────────────────
# Puerto dev del frontend: 8090 (bind a loopback).
# Para acceso desde máquina remota: ssh -L 8090:localhost:8090 usuario@servidor
API_BASE=http://localhost:8090
WEB_INFERRED_ORIGIN=http://localhost:8090
WEB_SECRET_KEY=change-this-dev-secret-key
LOG_LEVEL=DEBUG
ENV=development
REPORTS_API_BASE=http://api:8000
REPORTS_API_TIMEOUT=60
WEB_CHAT_ALLOWED_ORIGINS=
CHAT_UPLOAD_MAX_BYTES=15728640

# ─── Infraestructura (Sheets → DB) ────────────────────────────────────────────
INFRA_SHEET_ID=
INFRA_SHEET_NAME=Camaras
# Montar Keys/credentials.json dentro del contenedor o definir GOOGLE_CREDENTIALS_JSON
#GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ─── Servicio LibreOffice/UNO ─────────────────────────────────────────────────
OFFICE_ENABLE_UNO=true
OFFICE_LOG_LEVEL=INFO
OFFICE_SOFFICE_PORT=2002
OFFICE_SOFFICE_CONNECT_HOST=127.0.0.1
OFFICE_SERVICE_BASE=http://office:8090

# ─── Notificaciones por correo (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notificaciones@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=notificaciones@example.com
SMTP_FROM_NAME=LAS-FOCAS Dev Notificaciones
SMTP_USE_TLS=true

# ─── Slack (DEV) ──────────────────────────────────────────────────────────────
# IMPORTANTE: usar tokens de una Slack App de DESARROLLO separada de la de producción.
# Crear nueva app en https://api.slack.com/apps (ej: "LAS-FOCAS Dev").
# Dejar vacíos para arrancar sin el listener de ingresos técnicos.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
